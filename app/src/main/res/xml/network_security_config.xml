<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        SÉCURITÉ PRODUCTION (SEC-01)

        RÈGLE PAR DÉFAUT : HTTP AUTORISÉ
        - IPTV providers use arbitrary domains with HTTP (can't whitelist all)
        - Local/VPN backends use private IPs with HTTP
        - Plex Media Server local may use HTTP on LAN

        EXCEPTIONS HTTPS (strictes) :
        - plex.tv / plex.app : auth tokens, HTTPS obligatoire
    -->

    <!-- RÈGLE PAR DÉFAUT : HTTP AUTORISÉ (nécessaire pour IPTV + backends locaux) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- SÉCURITÉ STRICTE : Plex Cloud (HTTPS OBLIGATOIRE - protège les tokens) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">plex.tv</domain>
        <domain includeSubdomains="true">plex.app</domain>
    </domain-config>
</network-security-config>
